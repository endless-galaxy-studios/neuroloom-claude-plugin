{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/run_hook.py pyhooks.preload_context"
          }
        ]
      },
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/run_hook.py pyhooks.preload_context"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(bfs *)",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/run_hook.py pyhooks.preload_context"
          },
          {
            "type": "command",
            "if": "Bash(ugrep *)",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/run_hook.py pyhooks.preload_context"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/run_hook.py pyhooks.session_start"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Write|Edit|Bash|Agent|WebFetch|WebSearch|NotebookEdit|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/run_hook.py pyhooks.capture"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/run_hook.py pyhooks.code_graph_sync"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/run_hook.py pyhooks.cache_prefetch"
          }
        ]
      }
    ]
  }
}
